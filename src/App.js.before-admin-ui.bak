      "Athleisure-inspired Hanuman design with sharp print placement and breathable fabric.",
    colors: ["Red", "Black", "White"],
    sizes: ["S", "M", "L", "XL", "XXL"],
    fits: ["Regular", "Slim", "Oversized"],
    necks: ["Round Neck", "V Neck"],
    sleeves: ["Half Sleeve", "Raglan"],
    fabrics: ["180 GSM Cotton", "Dry Fit Blend"],
    printStyles: ["Front Print", "Back Print"]
  },
  {
    id: 4,
    name: "Narsimha Warrior Tee",
    category: "narsimha",
    price: 599,
    badge: "Limited",
    rating: 4.8,
    description:
      "Heavyweight warrior-inspired T-shirt designed for a standout premium look.",
    colors: ["Black", "Olive", "Sand"],
    sizes: ["M", "L", "XL", "XXL"],
    fits: ["Regular", "Oversized"],
    necks: ["Round Neck", "Polo Collar"],
    sleeves: ["Half Sleeve", "Full Sleeve"],
    fabrics: ["240 GSM Cotton", "Premium Terry"],
    printStyles: ["Front Print", "Front + Back Print", "Sleeve Detail"]
  },
  {
    id: 5,
    name: "Yodha Combat Tee",
    category: "yodha",
    price: 649,
    badge: "Trending",
    rating: 4.6,
    description:
      "Modern combat graphic tee with rugged styling and comfortable everyday wear.",
    colors: ["Army Green", "Black", "Charcoal"],
    sizes: ["S", "M", "L", "XL", "XXL"],
    fits: ["Regular", "Slim", "Oversized"],
    necks: ["Round Neck", "Henley"],
    sleeves: ["Half Sleeve", "Full Sleeve"],
    fabrics: ["200 GSM Cotton", "French Terry"],
    printStyles: ["Front Print", "Back Print", "Front + Back Print"]
  },
  {
    id: 6,
    name: "Astra Premium Tee",
    category: "astra",
    price: 699,
    badge: "Premium",
    rating: 4.9,
    description:
      "Premium celestial theme tee with extra customization options and richer fabric feel.",
    colors: ["Midnight Blue", "White", "Black", "Wine"],
    sizes: ["S", "M", "L", "XL", "XXL"],
    fits: ["Regular", "Oversized"],
    necks: ["Round Neck", "Polo Collar", "Mandarin"],
    sleeves: ["Half Sleeve", "Full Sleeve", "Drop Shoulder"],
    fabrics: ["240 GSM Cotton", "Premium Terry", "Bio Wash Cotton"],
    printStyles: ["Front Print", "Front + Back Print", "Embroidery Mix"]
  }
];

const tshirtCategories = [
  { value: "all", label: "All T-Shirts" },
  { value: "krishna", label: "Krishna" },
  { value: "mahadev", label: "Mahadev" },
  { value: "hanuman", label: "Hanuman" },
  { value: "narsimha", label: "Narsimha" },
  { value: "yodha", label: "Yodha" },
  { value: "astra", label: "Astra" }
];

const shirtCollections = ["Embroidery Shirts", "Plain Shirts", "Party Wear Shirts"];

const sortOptions = [
  { value: "featured", label: "Featured" },
  { value: "priceLow", label: "Price: Low to High" },
  { value: "priceHigh", label: "Price: High to Low" },
  { value: "rating", label: "Top Rated" }
];

const paymentOptions = [
  {
    value: "upi",
    title: "UPI",
    description: "Google Pay, PhonePe, Paytm, BHIM"
  },
  {
    value: "cod",
    title: "Cash on Delivery",
    description: "Pay at the time of delivery"
  },
  {
    value: "card",
    title: "Card",
    description: "Credit card, debit card, net banking"
  },
  {
    value: "aura",
    title: "Aura Points",
    description: "Use wallet balance for future drops"
  }
];

const initialCheckoutForm = {
  name: "",
  phone: "",
  address: "",
  city: "",
  pincode: "",
  landmark: ""
};

const formatCurrency = (amount) =>
  new Intl.NumberFormat("en-IN", {
    style: "currency",
    currency: "INR",
    maximumFractionDigits: 0
  }).format(amount);

const createDefaultConfig = (product) => ({
  color: product.colors[0],
  size: product.sizes[0],
  fit: product.fits[0],
  neck: product.necks[0],
  sleeve: product.sleeves[0],
  fabric: product.fabrics[0],
  printStyle: product.printStyles[0],
  quantity: 1
});

const menuStyle = {
  padding: "10px 0",
  borderBottom: "1px solid rgba(255,255,255,0.12)",
  cursor: "pointer"
};

const dropdownStyle = {
  position: "absolute",
  top: "42px",
  left: 0,
  background: "#ffffff",
  color: "#111827",
  borderRadius: "14px",
  boxShadow: "0 20px 40px rgba(15,23,42,0.15)",
  padding: "8px",
  minWidth: "180px",
  zIndex: 1000
};

const dropItemStyle = {
  padding: "10px 12px",
  cursor: "pointer",
  borderRadius: "10px",
  fontSize: "14px"
};

const pageShellStyle = {
  maxWidth: "1180px",
  margin: "0 auto",
  padding: "28px 20px 48px"
};

const sectionCardStyle = {
  background: "#ffffff",
  borderRadius: "24px",
  padding: "24px",
  boxShadow: "0 24px 60px rgba(15,23,42,0.08)"
};

const primaryButtonStyle = {
  padding: "12px 18px",
  borderRadius: "12px",
  border: "none",
  background: "#111111",
  color: "#ffffff",
  cursor: "pointer",
  fontWeight: 700
};

const secondaryButtonStyle = {
  padding: "12px 18px",
  borderRadius: "12px",
  border: "1px solid #d1d5db",
  background: "#ffffff",
  color: "#111111",
  cursor: "pointer",
  fontWeight: 700
};

const inputStyle = {
  width: "100%",
  padding: "12px 14px",
  borderRadius: "12px",
  border: "1px solid #d1d5db",
  outline: "none",
  fontSize: "15px",
  boxSizing: "border-box"
};

const selectStyle = {
  width: "100%",
  padding: "12px 14px",
  borderRadius: "12px",
  border: "1px solid #d1d5db",
  outline: "none",
  fontSize: "15px",
  background: "#ffffff"
};

const getOptionButtonStyle = (isActive) => ({
  padding: "10px 14px",
  borderRadius: "999px",
  border: isActive ? "1px solid #111111" : "1px solid #d1d5db",
  background: isActive ? "#111111" : "#ffffff",
  color: isActive ? "#ffffff" : "#111111",
  cursor: "pointer",
  fontWeight: 600
});

const getCategoryTabStyle = (isActive) => ({
  padding: "10px 16px",
  borderRadius: "999px",
  border: isActive ? "none" : "1px solid #d1d5db",
  background: isActive ? "#111111" : "#ffffff",
  color: isActive ? "#ffffff" : "#111111",
  cursor: "pointer",
  fontWeight: 700
});

const getPaymentCardStyle = (isActive) => ({
  border: isActive ? "2px solid #111111" : "1px solid #d1d5db",
  borderRadius: "18px",
  padding: "18px",
  cursor: "pointer",
  background: isActive ? "#f8fafc" : "#ffffff"
});

export default function App() {
  const [user, setUser] = useState(null);
  const [menuOpen, setMenuOpen] = useState(false);
  const [activePage, setActivePage] = useState("home");
  const [history, setHistory] = useState([]);
  const [showTshirtMenu, setShowTshirtMenu] = useState(false);
  const [showShirtMenu, setShowShirtMenu] = useState(false);
  const [selectedCategory, setSelectedCategory] = useState("all");
  const [searchTerm, setSearchTerm] = useState("");
  const [sortBy, setSortBy] = useState("featured");
  const [selectedProduct, setSelectedProduct] = useState(null);
  const [productConfig, setProductConfig] = useState(null);
  const [cart, setCart] = useState([]);
  const [wishlist, setWishlist] = useState([]);
  const [orders, setOrders] = useState([]);
  const [showAdded, setShowAdded] = useState(false);
  const [addedMessage, setAddedMessage] = useState("");
  const [checkoutForm, setCheckoutForm] = useState(initialCheckoutForm);
  const [paymentMethod, setPaymentMethod] = useState("upi");

  const tshirtRef = useRef(null);
  const shirtRef = useRef(null);
  const menuRef = useRef(null);

  const cartCount = cart.reduce((count, item) => count + item.quantity, 0);
  const cartTotal = cart.reduce((total, item) => total + item.price * item.quantity, 0);
  const auraPoints = 120;

  useEffect(() => {
    const handleClickOutside = (event) => {
      if (tshirtRef.current && !tshirtRef.current.contains(event.target)) {
        setShowTshirtMenu(false);
      }

      if (shirtRef.current && !shirtRef.current.contains(event.target)) {
        setShowShirtMenu(false);
      }

      if (menuRef.current && !menuRef.current.contains(event.target)) {
        setMenuOpen(false);
      }
    };

    document.addEventListener("mousedown", handleClickOutside);
    return () => {
      document.removeEventListener("mousedown", handleClickOutside);
    };
  }, []);

  useEffect(() => {
    if (!showAdded) {
      return undefined;
    }

    const timer = window.setTimeout(() => {
      setShowAdded(false);
    }, 1800);

    return () => window.clearTimeout(timer);
  }, [showAdded]);

  const loginWithGoogle = async () => {
    try {
      const provider = new GoogleAuthProvider();
      const result = await signInWithPopup(auth, provider);

      setUser({
        name: result.user.displayName,
        email: result.user.email,
        photo: result.user.photoURL
      });
      setMenuOpen(false);
    } catch (error) {
      console.log(error);
      alert("Login failed. Please try again.");
    }
  };

  const logout = () => {
    setUser(null);
    setMenuOpen(false);
    setHistory([]);
    setActivePage("home");
  };

  const navigateTo = (page) => {
    if (page === activePage) {
      setMenuOpen(false);
      return;
    }

    setHistory((prev) => [...prev, activePage]);
    setActivePage(page);
    setMenuOpen(false);
    setShowTshirtMenu(false);
    setShowShirtMenu(false);
  };

  const goHome = () => {
    setHistory([]);
    setActivePage("home");
    setMenuOpen(false);
    setShowTshirtMenu(false);
    setShowShirtMenu(false);
  };

  const goBack = () => {
    const previousPage = history[history.length - 1] || "home";
    setHistory((prev) => prev.slice(0, -1));
    setActivePage(previousPage);
    setMenuOpen(false);
    setShowTshirtMenu(false);
    setShowShirtMenu(false);
  };

  const selectCategory = (category) => {
    setSelectedCategory(category);
    setShowTshirtMenu(false);

    if (activePage !== "home") {
      navigateTo("home");
    }
  };

  const openShirtCollection = (collectionName) => {
    setShowShirtMenu(false);
    setAddedMessage(`${collectionName} section will be added next.`);
    setShowAdded(true);
  };

  const openProduct = (product) => {
    setSelectedProduct(product);
    setProductConfig(createDefaultConfig(product));
    navigateTo("productDetails");
  };

  const updateProductConfig = (field, value) => {
    setProductConfig((prev) => ({
      ...prev,
      [field]: value
    }));
  };

  const addConfiguredProductToCart = (product = selectedProduct, config = productConfig) => {
    if (!product || !config) {
      return;
    }

    const quantity = Math.max(1, Number(config.quantity) || 1);
    const cartItem = {
      cartId: `${product.id}-${Date.now()}`,
      productId: product.id,
      name: product.name,
      category: product.category,
      price: product.price,
      color: config.color,
      size: config.size,
      fit: config.fit,
      neck: config.neck,
      sleeve: config.sleeve,
      fabric: config.fabric,
      printStyle: config.printStyle,
      quantity
    };

    setCart((prev) => [...prev, cartItem]);
    setAddedMessage(`${product.name} added to cart.`);
    setShowAdded(true);
  };

  const addAndGoToCart = () => {
    addConfiguredProductToCart();
    navigateTo("cart");
  };

  const toggleWishlist = (product) => {
    setWishlist((prev) => {
      const exists = prev.some((item) => item.id === product.id);
      return exists ? prev.filter((item) => item.id !== product.id) : [product, ...prev];
    });
  };

  const updateCartQuantity = (cartId, change) => {
    setCart((prev) =>
      prev.map((item) =>
        item.cartId === cartId
          ? {
              ...item,
              quantity: Math.max(1, item.quantity + change)
            }
          : item
      )
    );
  };

  const removeFromCart = (cartId) => {
    setCart((prev) => prev.filter((item) => item.cartId !== cartId));
  };

  const handleCheckoutChange = (event) => {
    const { name, value } = event.target;
    setCheckoutForm((prev) => ({
      ...prev,
      [name]: value
    }));
  };

  const proceedToPayment = () => {
    const requiredFields = ["name", "phone", "address", "city", "pincode"];
    const hasMissingField = requiredFields.some(
      (field) => !checkoutForm[field].trim()
    );

    if (hasMissingField) {
      alert("Please fill your name, phone, address, city and pincode.");
      return;
    }

    navigateTo("paymentMethod");
  };

  const placeOrder = () => {
    if (cart.length === 0) {
      alert("Your cart is empty.");
      return;
    }

    const orderId = `VA-${Date.now().toString().slice(-6)}`;
    const order = {
      id: orderId,
      date: new Date().toLocaleString("en-IN"),
      paymentMethod,
      status: paymentMethod === "cod" ? "Order Confirmed" : "Payment Received",
      items: cart,
      total: cartTotal,
      customer: checkoutForm
    };

    setOrders((prev) => [order, ...prev]);
    setCart([]);
    setCheckoutForm(initialCheckoutForm);
    setPaymentMethod("upi");
    setHistory(["home"]);
    setActivePage("orders");
    setAddedMessage(`Order ${orderId} placed successfully.`);
    setShowAdded(true);
  };

  const filteredProducts = products
    .filter((product) => {
      const matchesCategory =
        selectedCategory === "all" || product.category === selectedCategory;
      const searchableText = `${product.name} ${product.category} ${product.description}`.toLowerCase();
      const matchesSearch = searchableText.includes(searchTerm.toLowerCase());
      return matchesCategory && matchesSearch;
    })
    .sort((left, right) => {
      if (sortBy === "priceLow") {
        return left.price - right.price;
      }

      if (sortBy === "priceHigh") {
        return right.price - left.price;
      }

      if (sortBy === "rating") {
        return right.rating - left.rating;
      }

      return 0;
    });

  const BackButton = ({ label = "Back" }) => (
    <button
      onClick={goBack}
      style={{
        ...secondaryButtonStyle,
        marginBottom: "20px"
      }}
    >
      {label}
    </button>
  );

  const renderOptionGroup = (label, field, options) => (
    <div style={{ marginBottom: "18px" }}>
      <p style={{ margin: "0 0 10px", fontSize: "14px", fontWeight: 700 }}>
        {label}
      </p>
      <div style={{ display: "flex", flexWrap: "wrap", gap: "10px" }}>
        {options.map((option) => (
          <button
            key={option}
            onClick={() => updateProductConfig(field, option)}
            style={getOptionButtonStyle(productConfig?.[field] === option)}
          >
            {option}
          </button>
        ))}
      </div>
    </div>
  );

  return (
    <div
      style={{
        minHeight: "100vh",
        background:
          "linear-gradient(180deg, #f8fafc 0%, #f5f0e8 42%, #ffffff 100%)",
        color: "#111827",
        fontFamily: "Arial, sans-serif"
      }}
    >
      <nav
        style={{
          position: "sticky",
          top: 0,
          zIndex: 100,
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          flexWrap: "wrap",
          gap: "18px",
          padding: "12px 18px",
          background: "rgba(0, 0, 0, 0.92)",
          color: "#ffffff",
          backdropFilter: "blur(10px)"
        }}
      >
        <div style={{ display: "flex", alignItems: "center", gap: "18px", flexWrap: "wrap" }}>
          <button
            onClick={() => setMenuOpen(true)}
            style={{
              background: "transparent",
              color: "#ffffff",
              border: "none",
              fontSize: "28px",
              cursor: "pointer"
            }}
          >
            =
          </button>

          <div style={{ position: "relative" }} ref={tshirtRef}>
            <h3
              onClick={() => setShowTshirtMenu((prev) => !prev)}
              style={{ cursor: "pointer", margin: 0 }}
            >
              T-Shirts
            </h3>

            {showTshirtMenu && (
              <div style={dropdownStyle}>
                {tshirtCategories.map((category) => (
                  <p
                    key={category.value}
                    onClick={() => selectCategory(category.value)}
                    style={{
                      ...dropItemStyle,
                      background:
                        selectedCategory === category.value ? "#f3f4f6" : "transparent"
                    }}
                  >
                    {category.label}
                  </p>
                ))}
              </div>
            )}
          </div>

          <div style={{ position: "relative" }} ref={shirtRef}>
            <h3
              onClick={() => setShowShirtMenu((prev) => !prev)}
              style={{ cursor: "pointer", margin: 0 }}
            >
              Shirts
            </h3>

            {showShirtMenu && (
              <div style={dropdownStyle}>
                {shirtCollections.map((collection) => (
                  <p
                    key={collection}
                    onClick={() => openShirtCollection(collection)}
                    style={dropItemStyle}
                  >
                    {collection}
                  </p>
                ))}
              </div>
            )}
          </div>
        </div>

        <div
          onClick={goHome}
          style={{
            display: "flex",
            alignItems: "center",
            gap: "12px",
            cursor: "pointer"
          }}
        >
          <video
            src={logoVideo}
            autoPlay
            loop
            muted
            playsInline
            style={{
              height: "68px",
              width: "68px",
              objectFit: "cover",
              borderRadius: "18px"
            }}
          />
          <div>
            <p style={{ margin: 0, fontSize: "13px", letterSpacing: "2px" }}>
              
            </p>
            <h2 style={{ margin: "4px 0 0", fontSize: "22px" }}>
              Premium T-Shirt Studio
            </h2>
          </div>
        </div>

        <div style={{ display: "flex", alignItems: "center", gap: "18px", flexWrap: "wrap" }}>
          <div
            style={{
              display: "flex",
              alignItems: "center",
              border: "1px solid rgba(255,255,255,0.2)",
              borderRadius: "999px",
              padding: "6px 12px",
              background: "rgba(255,255,255,0.08)"
            }}
          >
            <input
              value={searchTerm}
              onChange={(event) => setSearchTerm(event.target.value)}
              placeholder="Search design or theme"
              style={{
                border: "none",
                outline: "none",
                background: "transparent",
                color: "#ffffff",
                width: "180px",
                fontSize: "14px"
              }}
            />
          </div>

          <button
            onClick={() => navigateTo("wallet")}
            style={{ background: "transparent", border: "none", color: "#ffffff", cursor: "pointer" }}
            aria-label="Wallet"
          >
            Wallet
          </button>

          <button
            onClick={() => navigateTo("wishlist")}
            style={{ background: "transparent", border: "none", color: "#ffffff", cursor: "pointer" }}
            aria-label="Wishlist"
          >
            Wishlist {wishlist.length > 0 ? `(${wishlist.length})` : ""}
          </button>

          <button
            onClick={() => navigateTo("cart")}
            style={{
              position: "relative",
              background: "transparent",
              border: "none",
              color: "#ffffff",
              cursor: "pointer",
              fontWeight: 700
            }}
            aria-label="Cart"
          >
            Cart
            {cartCount > 0 && (
              <span
                style={{
                  position: "absolute",
                  top: "-10px",
                  right: "-18px",
                  minWidth: "20px",
                  height: "20px",
                  borderRadius: "999px",
                  background: "#ef4444",
                  color: "#ffffff",
                  fontSize: "11px",
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                  padding: "0 5px"
                }}
              >
                {cartCount}
              </span>
            )}
          </button>
        </div>
      </nav>

      {showAdded && (
        <div
          style={{
            position: "fixed",
            top: "92px",
            right: "20px",
            background: "#111111",
            color: "#ffffff",
            padding: "12px 16px",
            borderRadius: "14px",
            zIndex: 9999,
            boxShadow: "0 18px 40px rgba(15,23,42,0.24)"
          }}
        >
          {addedMessage}
        </div>
      )}

      {menuOpen && (
        <>
          <div
            style={{
              position: "fixed",
              inset: 0,
              background: "rgba(0,0,0,0.3)",
              zIndex: 50
            }}
          />
          <div
            ref={menuRef}
            style={{
              position: "fixed",
              top: 0,
              left: 0,
              width: "280px",
              height: "100%",
              background: "#050505",
              color: "#ffffff",
              padding: "24px",
              zIndex: 60,
              boxSizing: "border-box"
            }}
          >
            <div
              style={{
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between"
              }}
            >
              <h3 style={{ margin: 0 }}>Menu</h3>
              <button
                onClick={() => setMenuOpen(false)}
                style={{
                  background: "transparent",
                  border: "none",
                  color: "#ffffff",
                  cursor: "pointer",
                  fontSize: "18px"
                }}
              >
                X
              </button>
            </div>

            <div style={{ marginTop: "24px" }}>
              {user ? (
                <>
                  <img
                    src={user.photo}
                    alt={user.name}
                    style={{ width: "58px", height: "58px", borderRadius: "50%" }}
                  />
                  <h3 style={{ marginBottom: "4px" }}>{user.name}</h3>
                  <p style={{ margin: 0, color: "#9ca3af" }}>{user.email}</p>
                </>
              ) : (
                <>
                  <h3 style={{ marginBottom: "6px" }}>Guest User</h3>
                  <p style={{ marginTop: 0, color: "#9ca3af" }}>
                    Login for a faster checkout experience.
                  </p>
                </>
              )}
