                    <br />
                    Cart quantity update
                    <br />
                    Checkout and payment
                    <br />
                    Saved orders and wishlist
                  </p>
                </div>
                <img
                  src={logo}
                  alt=""
                  style={{
                    width: "110px",
                    height: "110px",
                    borderRadius: "24px",
                    objectFit: "cover",
                    boxShadow: "0 20px 35px rgba(0,0,0,0.25)"
                  }}
                />
              </div>

              <div
                style={{
                  display: "grid",
                  gridTemplateColumns: "repeat(2, minmax(120px, 1fr))",
                  gap: "12px"
                }}
              >
                {[
                  "Multiple sizes",
                  "Premium fabric choices",
                  "Fit and neck style",
                  "Order summary"
                ].map((item) => (
                  <div
                    key={item}
                    style={{
                      border: "1px solid rgba(255,255,255,0.15)",
                      borderRadius: "16px",
                      padding: "14px",
                      background: "rgba(255,255,255,0.06)"
                    }}
                  >
                    {item}
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section style={{ marginTop: "28px", ...sectionCardStyle }}>
            <div
              style={{
                display: "flex",
                alignItems: "center",
                justifyContent: "space-between",
                flexWrap: "wrap",
                gap: "16px"
              }}
            >
              <div>
                <h2 style={{ margin: "0 0 8px" }}>Browse the catalog</h2>
                <p style={{ margin: 0, color: "#6b7280" }}>
                  Choose a theme, sort the products, then open a product to
                  customize it fully.
                </p>
              </div>

              <div style={{ minWidth: "220px" }}>
                <select
                  value={sortBy}
                  onChange={(event) => setSortBy(event.target.value)}
                  style={selectStyle}
                >
                  {sortOptions.map((option) => (
                    <option key={option.value} value={option.value}>
                      {option.label}
                    </option>
                  ))}
                </select>
              </div>
            </div>

            <div
              style={{
                display: "flex",
                flexWrap: "wrap",
                gap: "12px",
                marginTop: "20px"
              }}
            >
              {tshirtCategories.map((category) => (
                <button
                  key={category.value}
                  onClick={() => setSelectedCategory(category.value)}
                  style={getCategoryTabStyle(selectedCategory === category.value)}
                >
                  {category.label}
                </button>
              ))}
            </div>
          </section>

          <section
            style={{
              marginTop: "28px",
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(260px, 1fr))",
              gap: "20px"
            }}
          >
            {filteredProducts.map((product) => {
              const inWishlist = wishlist.some((item) => item.id === product.id);

              return (
                <article key={product.id} style={sectionCardStyle}>
                  <div
                    style={{
                      height: "220px",
                      borderRadius: "20px",
                      background:
                        "linear-gradient(145deg, #111827 0%, #374151 45%, #92400e 100%)",
                      color: "#ffffff",
                      padding: "20px",
                      display: "flex",
                      flexDirection: "column",
                      justifyContent: "space-between"
                    }}
                  >
                    <div style={{ display: "flex", justifyContent: "space-between", gap: "12px" }}>
                      <span
                        style={{
                          alignSelf: "flex-start",
                          background: "rgba(255,255,255,0.12)",
                          padding: "6px 10px",
                          borderRadius: "999px",
                          fontSize: "12px"
                        }}
                      >
                        {product.badge}
                      </span>
                      <button
                        onClick={() => toggleWishlist(product)}
                        style={{
                          background: "rgba(255,255,255,0.12)",
                          border: "none",
                          color: "#ffffff",
                          width: "38px",
                          height: "38px",
                          borderRadius: "50%",
                          cursor: "pointer"
                        }}
                      >
                        {inWishlist ? "Saved" : "Save"}
                      </button>
                    </div>
                    <div>
                      <p style={{ margin: 0, fontSize: "14px", color: "#fde68a" }}>
                        Rating {product.rating}
                      </p>
                      <h3 style={{ margin: "8px 0 0", fontSize: "24px" }}>{product.name}</h3>
                    </div>
                  </div>

                  <p style={{ margin: "16px 0 10px", color: "#4b5563", lineHeight: 1.7 }}>
                    {product.description}
                  </p>

                  <div style={{ display: "flex", flexWrap: "wrap", gap: "8px", marginBottom: "14px" }}>
                    {product.sizes.map((size) => (
                      <span
                        key={size}
                        style={{
                          padding: "6px 10px",
                          borderRadius: "999px",
                          background: "#f3f4f6",
                          fontSize: "12px"
                        }}
                      >
                        {size}
                      </span>
                    ))}
                  </div>

                  <div
                    style={{
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "space-between",
                      flexWrap: "wrap",
                      gap: "12px"
                    }}
                  >
                    <div>
                      <p style={{ margin: 0, color: "#6b7280", fontSize: "14px" }}>
                        Starting from
                      </p>
                      <h3 style={{ margin: "6px 0 0" }}>{formatCurrency(product.price)}</h3>
                    </div>
                    <button onClick={() => openProduct(product)} style={primaryButtonStyle}>
                      Customize
                    </button>
                  </div>
                </article>
              );
            })}
          </section>

          {filteredProducts.length === 0 && (
            <div style={{ ...sectionCardStyle, marginTop: "28px", textAlign: "center" }}>
              <h3 style={{ marginTop: 0 }}>No products found</h3>
              <p style={{ marginBottom: 0, color: "#6b7280" }}>
                Try a different search keyword or switch the category.
              </p>
            </div>
          )}
        </div>
      )}

      {activePage === "productDetails" && (
        <div style={pageShellStyle}>
          <BackButton />

          {selectedProduct && productConfig ? (
            <section
              style={{
                display: "grid",
                gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))",
                gap: "24px"
              }}
            >
              <div style={sectionCardStyle}>
                <div
                  style={{
                    minHeight: "420px",
                    borderRadius: "24px",
                    background:
                      "linear-gradient(145deg, #111827 0%, #4b5563 52%, #c2410c 100%)",
                    padding: "24px",
                    color: "#ffffff",
                    display: "flex",
                    flexDirection: "column",
                    justifyContent: "space-between"
                  }}
                >
                  <div style={{ display: "flex", justifyContent: "space-between", gap: "12px" }}>
                    <span
                      style={{
                        background: "rgba(255,255,255,0.14)",
                        padding: "6px 12px",
                        borderRadius: "999px",
                        fontSize: "12px"
                      }}
                    >
                      {selectedProduct.badge}
                    </span>
                    <span
                      style={{
                        background: "rgba(255,255,255,0.14)",
                        padding: "6px 12px",
                        borderRadius: "999px",
                        fontSize: "12px"
                      }}
                    >
                      Rating {selectedProduct.rating}
                    </span>
                  </div>

                  <div style={{ textAlign: "center" }}>
                    <img
                      src={logo}
                      alt={selectedProduct.name}
                      style={{
                        width: "180px",
                        height: "180px",
                        objectFit: "cover",
                        borderRadius: "28px",
                        boxShadow: "0 24px 40px rgba(0,0,0,0.25)"
                      }}
                    />
                  </div>

                  <div>
                    <h2 style={{ margin: "0 0 10px" }}>{selectedProduct.name}</h2>
                    <p style={{ margin: "0 0 10px", color: "rgba(255,255,255,0.82)" }}>
                      {selectedProduct.description}
                    </p>
                    <div style={{ display: "flex", flexWrap: "wrap", gap: "10px" }}>
                      <span
                        style={{
                          padding: "8px 12px",
                          borderRadius: "999px",
                          background: "rgba(255,255,255,0.12)"
                        }}
                      >
                        Color: {productConfig.color}
                      </span>
                      <span
                        style={{
                          padding: "8px 12px",
                          borderRadius: "999px",
                          background: "rgba(255,255,255,0.12)"
                        }}
                      >
                        Size: {productConfig.size}
                      </span>
                      <span
                        style={{
                          padding: "8px 12px",
                          borderRadius: "999px",
                          background: "rgba(255,255,255,0.12)"
                        }}
                      >
                        Fit: {productConfig.fit}
                      </span>
                    </div>
                  </div>
                </div>
              </div>

              <div style={sectionCardStyle}>
                <p
                  style={{
                    margin: 0,
                    fontSize: "13px",
                    letterSpacing: "3px",
                    textTransform: "uppercase",
                    color: "#92400e"
                  }}
                >
                  T-shirt options
                </p>
                <h1 style={{ margin: "10px 0 8px", fontSize: "36px", lineHeight: 1.1 }}>
                  {selectedProduct.name}
                </h1>
                <p style={{ margin: "0 0 18px", color: "#4b5563", lineHeight: 1.7 }}>
                  Add the same options that users expect on a T-shirt website
                  before they place the order.
                </p>
                <h2 style={{ marginTop: 0 }}>{formatCurrency(selectedProduct.price)}</h2>

                {renderOptionGroup("Choose color", "color", selectedProduct.colors)}
                {renderOptionGroup("Choose size", "size", selectedProduct.sizes)}
                {renderOptionGroup("Choose fit", "fit", selectedProduct.fits)}
                {renderOptionGroup("Neck style", "neck", selectedProduct.necks)}
                {renderOptionGroup("Sleeve style", "sleeve", selectedProduct.sleeves)}
                {renderOptionGroup("Fabric", "fabric", selectedProduct.fabrics)}
                {renderOptionGroup("Print style", "printStyle", selectedProduct.printStyles)}

                <div style={{ marginBottom: "22px" }}>
                  <p style={{ margin: "0 0 10px", fontSize: "14px", fontWeight: 700 }}>
                    Quantity
                  </p>
                  <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
                    <button
                      onClick={() =>
                        updateProductConfig(
                          "quantity",
                          Math.max(1, productConfig.quantity - 1)
                        )
                      }
                      style={secondaryButtonStyle}
                    >
                      -
                    </button>
                    <div
                      style={{
                        minWidth: "72px",
                        textAlign: "center",
                        padding: "12px 16px",
                        borderRadius: "12px",
                        background: "#f3f4f6",
                        fontWeight: 700
                      }}
                    >
                      {productConfig.quantity}
                    </div>
                    <button
                      onClick={() =>
                        updateProductConfig("quantity", productConfig.quantity + 1)
                      }
                      style={secondaryButtonStyle}
                    >
                      +
                    </button>
                  </div>
                </div>

                <div
                  style={{
                    border: "1px solid #e5e7eb",
                    borderRadius: "18px",
                    padding: "18px",
                    background: "#f8fafc",
                    marginBottom: "20px"
                  }}
                >
                  <h3 style={{ marginTop: 0 }}>Selection summary</h3>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Color: {productConfig.color}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Size: {productConfig.size}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Fit: {productConfig.fit}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Neck: {productConfig.neck}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Sleeve: {productConfig.sleeve}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Fabric: {productConfig.fabric}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Print: {productConfig.printStyle}
                  </p>
                  <p style={{ margin: "8px 0", color: "#4b5563" }}>
                    Quantity: {productConfig.quantity}
                  </p>
                  <h3 style={{ marginBottom: 0 }}>
                    Total: {formatCurrency(selectedProduct.price * productConfig.quantity)}
                  </h3>
                </div>

                <div style={{ display: "flex", gap: "12px", flexWrap: "wrap" }}>
                  <button onClick={addConfiguredProductToCart} style={primaryButtonStyle}>
                    Add to Cart
                  </button>
                  <button onClick={addAndGoToCart} style={secondaryButtonStyle}>
                    Add and View Cart
                  </button>
                </div>
              </div>
            </section>
          ) : (
            <div style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Product not found</h2>
              <p style={{ color: "#6b7280" }}>
                Go back to the homepage and select a product again.
              </p>
            </div>
          )}
        </div>
      )}

      {activePage === "wishlist" && (
        <div style={pageShellStyle}>
          <BackButton />
          <div style={sectionCardStyle}>
            <h2 style={{ marginTop: 0 }}>Wishlist</h2>
            {wishlist.length === 0 ? (
              <p style={{ marginBottom: 0, color: "#6b7280" }}>
                No saved products yet. Tap Save on any design you like.
              </p>
            ) : (
              <div
                style={{
                  display: "grid",
                  gridTemplateColumns: "repeat(auto-fit, minmax(240px, 1fr))",
                  gap: "18px"
                }}
              >
                {wishlist.map((product) => (
                  <div
                    key={product.id}
                    style={{
                      border: "1px solid #e5e7eb",
                      borderRadius: "18px",
                      padding: "18px"
                    }}
                  >
                    <h3 style={{ marginTop: 0 }}>{product.name}</h3>
                    <p style={{ color: "#6b7280", lineHeight: 1.7 }}>
                      {product.description}
                    </p>
                    <p style={{ fontWeight: 700 }}>{formatCurrency(product.price)}</p>
                    <button onClick={() => openProduct(product)} style={primaryButtonStyle}>
                      Customize
                    </button>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      {activePage === "cart" && (
        <div style={pageShellStyle}>
          <BackButton />

          <div
            style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(320px, 1fr))",
              gap: "24px"
            }}
          >
            <section style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Cart</h2>
              {cart.length === 0 ? (
                <>
                  <p style={{ color: "#6b7280" }}>
                    Your cart is empty. Customize a T-shirt and add it here.
                  </p>
                  <button onClick={goHome} style={primaryButtonStyle}>
                    Continue Shopping
                  </button>
                </>
              ) : (
                <div style={{ display: "grid", gap: "14px" }}>
                  {cart.map((item) => (
                    <div
                      key={item.cartId}
                      style={{
                        border: "1px solid #e5e7eb",
                        borderRadius: "18px",
                        padding: "18px"
                      }}
                    >
                      <div
                        style={{
                          display: "flex",
                          alignItems: "flex-start",
                          justifyContent: "space-between",
                          gap: "14px"
                        }}
                      >
                        <div>
                          <h3 style={{ margin: "0 0 8px" }}>{item.name}</h3>
                          <p style={{ margin: "4px 0", color: "#4b5563" }}>
                            {item.color} | {item.size} | {item.fit}
                          </p>
                          <p style={{ margin: "4px 0", color: "#4b5563" }}>
                            {item.neck} | {item.sleeve}
                          </p>
                          <p style={{ margin: "4px 0", color: "#4b5563" }}>
                            {item.fabric} | {item.printStyle}
                          </p>
                          <p style={{ margin: "10px 0 0", fontWeight: 700 }}>
                            {formatCurrency(item.price * item.quantity)}
                          </p>
                        </div>

                        <button
                          onClick={() => removeFromCart(item.cartId)}
                          style={secondaryButtonStyle}
                        >
                          Remove
                        </button>
                      </div>

                      <div style={{ display: "flex", alignItems: "center", gap: "10px", marginTop: "14px" }}>
                        <button
                          onClick={() => updateCartQuantity(item.cartId, -1)}
                          style={secondaryButtonStyle}
                        >
                          -
                        </button>
                        <div
                          style={{
                            minWidth: "58px",
                            textAlign: "center",
                            padding: "10px 12px",
                            borderRadius: "12px",
                            background: "#f3f4f6",
                            fontWeight: 700
                          }}
                        >
                          {item.quantity}
                        </div>
                        <button
                          onClick={() => updateCartQuantity(item.cartId, 1)}
                          style={secondaryButtonStyle}
                        >
                          +
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </section>

            <aside style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Order Summary</h2>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "12px 0",
                  borderBottom: "1px solid #e5e7eb"
                }}
              >
                <span>Items</span>
                <span>{cartCount}</span>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "12px 0",
                  borderBottom: "1px solid #e5e7eb"
                }}
              >
                <span>Shipping</span>
                <span>Free</span>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "16px 0 0",
                  fontWeight: 700,
                  fontSize: "18px"
                }}
              >
                <span>Total</span>
                <span>{formatCurrency(cartTotal)}</span>
              </div>

              <button
                onClick={() => navigateTo("checkout")}
                style={{
                  ...primaryButtonStyle,
                  width: "100%",
                  marginTop: "22px"
                }}
                disabled={cart.length === 0}
              >
                Proceed to Checkout
              </button>
            </aside>
          </div>
        </div>
      )}

      {activePage === "checkout" && (
        <div style={pageShellStyle}>
          <BackButton />

          <div
            style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(320px, 1fr))",
              gap: "24px"
            }}
          >
            <section style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Checkout Details</h2>
              <div style={{ display: "grid", gap: "14px" }}>
                <input
                  name="name"
                  value={checkoutForm.name}
                  onChange={handleCheckoutChange}
                  placeholder="Full name"
                  style={inputStyle}
                />
                <input
                  name="phone"
                  value={checkoutForm.phone}
                  onChange={handleCheckoutChange}
                  placeholder="Phone number"
                  style={inputStyle}
                />
                <input
                  name="address"
                  value={checkoutForm.address}
                  onChange={handleCheckoutChange}
                  placeholder="Full address"
                  style={inputStyle}
                />
                <input
                  name="city"
                  value={checkoutForm.city}
                  onChange={handleCheckoutChange}
                  placeholder="City"
                  style={inputStyle}
                />
                <input
                  name="pincode"
                  value={checkoutForm.pincode}
                  onChange={handleCheckoutChange}
                  placeholder="Pincode"
                  style={inputStyle}
                />
                <input
                  name="landmark"
                  value={checkoutForm.landmark}
                  onChange={handleCheckoutChange}
                  placeholder="Landmark (optional)"
                  style={inputStyle}
                />
              </div>
            </section>

            <aside style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Delivery Summary</h2>
              {cart.map((item) => (
                <div
                  key={item.cartId}
                  style={{
                    display: "flex",
                    justifyContent: "space-between",
                    gap: "12px",
                    padding: "12px 0",
                    borderBottom: "1px solid #e5e7eb"
                  }}
                >
                  <div>
                    <p style={{ margin: "0 0 4px", fontWeight: 700 }}>{item.name}</p>
                    <p style={{ margin: 0, color: "#6b7280", fontSize: "14px" }}>
                      {item.size} | {item.color} | Qty {item.quantity}
                    </p>
                  </div>
                  <span>{formatCurrency(item.price * item.quantity)}</span>
                </div>
              ))}

              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  paddingTop: "16px",
                  fontWeight: 700
                }}
              >
                <span>Total</span>
                <span>{formatCurrency(cartTotal)}</span>
              </div>

              <button
                onClick={proceedToPayment}
                style={{
                  ...primaryButtonStyle,
                  width: "100%",
                  marginTop: "22px"
                }}
              >
                Continue to Payment
              </button>
            </aside>
          </div>
        </div>
      )}

      {activePage === "paymentMethod" && (
        <div style={pageShellStyle}>
          <BackButton />

          <div
            style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(320px, 1fr))",
              gap: "24px"
            }}
          >
            <section style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Select Payment Method</h2>
              <div style={{ display: "grid", gap: "14px" }}>
                {paymentOptions.map((option) => (
                  <div
                    key={option.value}
                    style={getPaymentCardStyle(paymentMethod === option.value)}
                    onClick={() => setPaymentMethod(option.value)}
                  >
                    <h3 style={{ margin: "0 0 8px" }}>{option.title}</h3>
                    <p style={{ margin: 0, color: "#6b7280" }}>{option.description}</p>
                  </div>
                ))}
              </div>
            </section>

            <aside style={sectionCardStyle}>
              <h2 style={{ marginTop: 0 }}>Final Summary</h2>
              <p style={{ color: "#6b7280", lineHeight: 1.7 }}>
                Deliver to: {checkoutForm.name || "Guest"}, {checkoutForm.address || "-"},{" "}
                {checkoutForm.city || "-"} {checkoutForm.pincode || ""}
              </p>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "12px 0",
                  borderBottom: "1px solid #e5e7eb"
                }}
              >
                <span>Items</span>
                <span>{cartCount}</span>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  padding: "12px 0",
                  borderBottom: "1px solid #e5e7eb"
                }}
              >
                <span>Chosen payment</span>
                <span>
                  {paymentOptions.find((option) => option.value === paymentMethod)?.title}
                </span>
              </div>
              <div
                style={{
                  display: "flex",
                  justifyContent: "space-between",
                  paddingTop: "16px",
                  fontWeight: 700,
                  fontSize: "18px"
                }}
              >
                <span>Total</span>
                <span>{formatCurrency(cartTotal)}</span>
              </div>

              <button
                onClick={placeOrder}
                style={{
                  ...primaryButtonStyle,
                  width: "100%",
                  marginTop: "22px"
                }}
              >
                Place Order
              </button>
            </aside>
          </div>
        </div>
      )}

      {activePage === "orders" && (
        <div style={pageShellStyle}>
          <BackButton />
          <div style={sectionCardStyle}>
            <h2 style={{ marginTop: 0 }}>My Orders</h2>
            {orders.length === 0 ? (
              <p style={{ marginBottom: 0, color: "#6b7280" }}>
                No orders yet. After checkout, confirmed orders will appear here.
              </p>
            ) : (
              <div style={{ display: "grid", gap: "18px" }}>
                {orders.map((order) => (
                  <div
                    key={order.id}
                    style={{
                      border: "1px solid #e5e7eb",
                      borderRadius: "18px",
                      padding: "20px"
                    }}
                  >
                    <div
                      style={{
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "space-between",
                        flexWrap: "wrap",
                        gap: "12px"
                      }}
                    >
                      <div>
                        <h3 style={{ margin: "0 0 6px" }}>{order.id}</h3>
                        <p style={{ margin: 0, color: "#6b7280" }}>{order.date}</p>
                      </div>
                      <div
                        style={{
                          padding: "8px 12px",
                          borderRadius: "999px",
                          background: "#dcfce7",
                          color: "#166534",
                          fontWeight: 700
                        }}
                      >
                        {order.status}
                      </div>
                    </div>

                    <div style={{ marginTop: "16px", display: "grid", gap: "10px" }}>
                      {order.items.map((item) => (
                        <div
                          key={item.cartId}
                          style={{
                            padding: "14px",
                            borderRadius: "14px",
                            background: "#f8fafc"
                          }}
                        >
                          <strong>{item.name}</strong>
                          <p style={{ margin: "6px 0 0", color: "#4b5563" }}>
                            {item.color} | {item.size} | {item.fit} | Qty {item.quantity}
                          </p>
                          <p style={{ margin: "6px 0 0", color: "#4b5563" }}>
                            {item.neck} | {item.sleeve} | {item.fabric}
                          </p>
                        </div>
                      ))}
                    </div>

                    <div
                      style={{
                        display: "flex",
                        justifyContent: "space-between",
                        flexWrap: "wrap",
                        gap: "12px",
                        marginTop: "16px"
                      }}
                    >
                      <div>
                        <p style={{ margin: "0 0 6px", color: "#6b7280" }}>Delivery to</p>
                        <p style={{ margin: 0 }}>
                          {order.customer.name}, {order.customer.address}, {order.customer.city},{" "}
                          {order.customer.pincode}
                        </p>
                      </div>
                      <div>
                        <p style={{ margin: "0 0 6px", color: "#6b7280" }}>Payment</p>
                        <p style={{ margin: 0 }}>
                          {paymentOptions.find((option) => option.value === order.paymentMethod)?.title}
                        </p>
                      </div>
                      <div>
                        <p style={{ margin: "0 0 6px", color: "#6b7280" }}>Total</p>
                        <p style={{ margin: 0, fontWeight: 700 }}>{formatCurrency(order.total)}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      {activePage === "wallet" && (
        <div style={pageShellStyle}>
          <BackButton />
          <div
            style={{
              ...sectionCardStyle,
              background:
                "linear-gradient(135deg, rgba(17,17,17,0.95), rgba(14,116,144,0.92))",
              color: "#ffffff"
            }}
          >
            <p
              style={{
                marginTop: 0,
                fontSize: "13px",
                letterSpacing: "3px",
                textTransform: "uppercase",
                color: "#bfdbfe"
              }}
            >
              Wallet
            </p>
            <h2 style={{ margin: "8px 0 6px", fontSize: "42px" }}>{auraPoints} Aura Points</h2>
            <p style={{ margin: 0, color: "rgba(255,255,255,0.82)", lineHeight: 1.7 }}>
              1 Aura Point can be used like 1 INR on future orders. This section is now
              connected and ready for payment method selection.
            </p>
          </div>
        </div>
      )}

      {activePage === "terms" && (
        <div style={pageShellStyle}>
          <BackButton />
          <div style={sectionCardStyle}>
            <h2 style={{ marginTop: 0 }}>Terms and Conditions</h2>
            <p style={{ color: "#4b5563", lineHeight: 1.8 }}>
              By using this website and placing an order, the customer agrees to
              the store terms. Products must be used lawfully, pricing errors may
              be corrected, returns are only reviewed for approved cases, and
              Aura Points remain non-transferable. Orders become final after
              confirmation, and delivery delays from courier partners are outside
              direct store control.
            </p>
            <p style={{ color: "#4b5563", lineHeight: 1.8, marginBottom: 0 }}>
              The store may update product details, pricing, and policy text when
              required. For any issue, customers can contact
              vastraaura@gmail.com.
            </p>
          </div>
        </div>
      )}
    </div>
  );
}
