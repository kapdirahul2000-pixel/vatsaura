import React, { useEffect, useRef, useState } from "react";
import "./App.css";
import { auth } from "./firebase";
import { GoogleAuthProvider, signInWithPopup } from "firebase/auth";
import logoVideo from "./logo.mp4";
import logo from "./logo.png";

const products = [
  {
    id: 1,
    name: "Krishna Oversized Tee",
    category: "krishna",
    price: 499,
    badge: "Best Seller",
    rating: 4.9,
    description:
      "Bhakti-inspired streetwear tee with soft cotton feel and bold front artwork.",
    colors: ["Black", "White", "Saffron", "Royal Blue"],
    sizes: ["S", "M", "L", "XL", "XXL"],
    fits: ["Regular", "Oversized"],
    necks: ["Round Neck", "Mandarin"],
    sleeves: ["Half Sleeve", "Full Sleeve"],
    fabrics: ["180 GSM Cotton", "240 GSM Cotton"],
    printStyles: ["Front Print", "Front + Back Print"]
  },
  {
