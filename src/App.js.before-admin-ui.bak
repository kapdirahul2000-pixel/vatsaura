                  style={{
                    ...primaryButtonStyle,
                    background: "#ffffff",
                    color: "#111111"
                  }}
                >
                  Shop Collection
                </button>
                <button
                  onClick={() => navigateTo("orders")}
                  style={{
                    ...secondaryButtonStyle,
                    background: "transparent",
                    color: "#ffffff",
                    border: "1px solid rgba(255,255,255,0.28)"
                  }}
                >
                  View Orders
                </button>
              </div>
            </div>

            <div
              style={{
                minHeight: "280px",
                borderRadius: "24px",
                background:
                  "radial-gradient(circle at top, rgba(255,255,255,0.24), rgba(255,255,255,0.03))",
                padding: "24px",
                display: "flex",
                flexDirection: "column",
                justifyContent: "space-between"
              }}
            >
              <div style={{ display: "flex", justifyContent: "space-between", gap: "18px" }}>
                <div>
                  <p style={{ margin: 0, color: "#fde68a", fontWeight: 700 }}>Live Features</p>
                  <p style={{ margin: "8px 0 0", lineHeight: 1.7 }}>
