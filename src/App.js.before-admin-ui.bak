              </p>
              <p style={menuStyle} onClick={() => navigateTo("wishlist")}>
                Wishlist
              </p>
              <p style={menuStyle} onClick={() => navigateTo("wallet")}>
                Wallet
              </p>
              <p
                style={menuStyle}
                onClick={() => alert("Contact: vastraaura@gmail.com")}
              >
                Contact Us
              </p>
              <p style={menuStyle} onClick={() => navigateTo("terms")}>
                T and C
              </p>
              {user && (
                <p style={menuStyle} onClick={logout}>
                  Logout
                </p>
              )}
            </div>
          </div>
        </>
      )}

      {activePage === "home" && (
        <div style={pageShellStyle}>
          <section
            style={{
              ...sectionCardStyle,
              display: "grid",
              gridTemplateColumns: "repeat(auto-fit, minmax(280px, 1fr))",
              gap: "24px",
              background:
                "linear-gradient(135deg, rgba(17,17,17,0.96), rgba(120,53,15,0.94))",
              color: "#ffffff"
            }}
          >
            <div>
              <p
                style={{
                  marginTop: 0,
                  fontSize: "13px",
                  letterSpacing: "3px",
                  textTransform: "uppercase",
                  color: "#fde68a"
                }}
              >
                Design your drop
              </p>
              <h1 style={{ margin: "0 0 14px", fontSize: "44px", lineHeight: 1.1 }}>
                Fix order flow and add all important T-shirt options in one place.
              </h1>
              <p
                style={{
                  margin: "0 0 22px",
                  color: "rgba(255,255,255,0.82)",
