    description:
      "Dark aesthetic Mahadev tee built for a premium oversized fall and all-day comfort.",
    colors: ["Black", "Ash Grey", "Navy"],
    sizes: ["S", "M", "L", "XL", "XXL"],
    fits: ["Regular", "Oversized"],
    necks: ["Round Neck", "Polo Collar"],
    sleeves: ["Half Sleeve", "Full Sleeve"],
    fabrics: ["240 GSM Cotton", "French Terry"],
