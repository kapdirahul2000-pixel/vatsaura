}

// ---------------- STYLES ----------------
const menuStyle = {
padding: "10px",
borderBottom: "1px solid grey",
cursor: "pointer"
};

const dropdownStyle = {
position: "absolute",
top: "35px",
left: "0",
background: "white",
color: "black",
borderRadius: "8px",
boxShadow: "0 5px 15px rgba(0,0,0,0.2)",
padding: "8px",
minWidth: "150px",
zIndex: 1000
};

const dropItem = {
padding: "8px",
cursor: "pointer",
borderBottom: "1px solid #eee"
};
