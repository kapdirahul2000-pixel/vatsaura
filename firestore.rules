rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == "admin" ||
        request.auth.token.email in [
          "kapdirahul2000@gmail.com",
          "vatsaurateam@gmail.com"
        ]
      );
    }

    function isCurrentUserEmail(email) {
      return signedIn() &&
        email is string &&
        request.auth.token.email is string &&
        request.auth.token.email == email;
    }

    function auraFieldsUnchanged() {
      return request.resource.data.auraPoints == resource.data.auraPoints &&
        request.resource.data.auraHistory == resource.data.auraHistory;
    }

    function isOrderOwner(data) {
      return signedIn() && (
        (data.userUid is string && data.userUid == request.auth.uid) ||
        (data.userEmail is string && isCurrentUserEmail(data.userEmail))
      );
    }

    function isReturnRequestUpdate() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let deliveredAt = resource.data.deliveredAt;

      return isOrderOwner(resource.data) &&
        deliveredAt != null &&
        (deliveredAt is int || deliveredAt is float) &&
        resource.data.status == "Delivered" &&
        request.time.toMillis() <= deliveredAt + 259200000 &&
        resource.data.returnRequested != true &&
        changed.hasOnly(["returnRequested", "returnRequestStatus", "returnRequest"]) &&
        request.resource.data.returnRequested == true &&
        request.resource.data.returnRequestStatus == "Pending" &&
        request.resource.data.returnRequest is map &&
        request.resource.data.returnRequest.name is string &&
        request.resource.data.returnRequest.phone is string &&
        request.resource.data.returnRequest.reason is string &&
        request.resource.data.returnRequest.requestedAt is int &&
        request.resource.data.returnRequest.requestedAtLabel is string &&
        request.resource.data.returnRequest.name.size() > 0 &&
        request.resource.data.returnRequest.phone.size() > 0 &&
        request.resource.data.returnRequest.reason.size() > 0;
    }

    function validVisitorId(value) {
      return value is string && value.size() > 3 && value.size() <= 80;
    }

    function validVisitorDateKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validAnalyticsTimestamp(value) {
      return value is int && value > 0;
    }

    function validVisitorProfile(visitorId) {
      return request.resource.data.id == visitorId &&
        validVisitorId(request.resource.data.id) &&
        validAnalyticsTimestamp(request.resource.data.createdAt) &&
        validAnalyticsTimestamp(request.resource.data.lastSeenAt) &&
        validVisitorDateKey(request.resource.data.firstVisitDate) &&
        validVisitorDateKey(request.resource.data.lastVisitDate) &&
        request.resource.data.userAgent is string &&
        request.resource.data.userAgent.size() <= 280;
    }

    function validVisitorDay(dayId) {
      return request.resource.data.id == dayId &&
        request.resource.data.visitorId is string &&
        validVisitorId(request.resource.data.visitorId) &&
        validVisitorDateKey(request.resource.data.dateKey) &&
        validAnalyticsTimestamp(request.resource.data.createdAt) &&
        validAnalyticsTimestamp(request.resource.data.lastSeenAt);
    }

    function validVisitorSession(sessionId) {
      return request.resource.data.id == sessionId &&
        validVisitorId(request.resource.data.id) &&
        request.resource.data.visitorId is string &&
        validVisitorId(request.resource.data.visitorId) &&
        request.resource.data.page is string &&
        request.resource.data.page.size() > 0 &&
        request.resource.data.page.size() <= 80 &&
        validAnalyticsTimestamp(request.resource.data.startedAt) &&
        validAnalyticsTimestamp(request.resource.data.lastSeenAt) &&
        request.resource.data.userAgent is string &&
        request.resource.data.userAgent.size() <= 280;
    }

    match /visitorProfiles/{visitorId} {
      allow read: if isAdmin();
      allow create, update: if validVisitorProfile(visitorId);
      allow delete: if false;
    }

    match /visitorDays/{dayId} {
      allow read: if isAdmin();
      allow create, update: if validVisitorDay(dayId);
      allow delete: if false;
    }

    match /visitorSessions/{sessionId} {
      allow read: if isAdmin();
      allow create, update: if validVisitorSession(sessionId);
      allow delete: if false;
    }

    match /appState/primary {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || isCurrentUserEmail(userId);
      allow create: if isAdmin() || (
        isCurrentUserEmail(userId) &&
        request.resource.data.email is string &&
        request.resource.data.email == userId &&
        request.resource.data.auraPoints == 0
      );
      allow update: if isAdmin() || (
        isCurrentUserEmail(userId) &&
        resource.data.email is string &&
        resource.data.email == userId &&
        request.resource.data.email is string &&
        request.resource.data.email == userId &&
        auraFieldsUnchanged()
      );
      allow delete: if isAdmin() || isCurrentUserEmail(userId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isOrderOwner(resource.data);
      allow create: if isAdmin() || isOrderOwner(request.resource.data);
      allow update: if isAdmin() || isReturnRequestUpdate();
      allow delete: if isAdmin();
    }
  }
}
